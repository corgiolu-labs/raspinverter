# Copia in .env o esporta nell'ambiente del processo (nessun segreto qui: solo esempi).
# Le stesse variabili sono documentate in README; i valori di default restano in config JSON.

# Server HTTP Flask
# PORT=8000

# Percorso file JSON di configurazione inverter
# INVERTER_CONFIG=config/inverter_config.json

# Modbus RTU (sovrascrivono chiavi in serial.* del JSON se impostate)
# INVERTER_MODBUS_SERIAL_PORT=/dev/serial0
# INVERTER_MODBUS_BAUDRATE=9600
# INVERTER_MODBUS_PARITY=N
# INVERTER_MODBUS_STOPBITS=1
# INVERTER_MODBUS_BYTESIZE=8
# INVERTER_MODBUS_TIMEOUT=1.0
# INVERTER_UNIT_ID=1

# Intervallo polling campioni (secondi)
# POLL_INTERVAL_SEC=5

# I2C (se usato; richiede smbus2 e sezione i2c nel JSON)
# I2C_ENABLED=0
# I2C_BUS=1
